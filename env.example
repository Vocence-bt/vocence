# Vocence – copy to .env and fill per role.
# Only variables that have no default in config are listed.
# Duplicated across sections when a variable is used by more than one role.

# =============================================================================
# MINER
# =============================================================================

CHUTES_API_KEY=

# Optional: for HuggingFace models
# HF_AUTH_TOKEN=

# =============================================================================
# VALIDATOR
# =============================================================================

CHUTES_API_KEY=

OPENAI_API_KEY=

# Corpus (read owner's bucket; owner-provided sub_key)
HIPPIUS_CORPUS_ACCESS_KEY=
HIPPIUS_CORPUS_SECRET_KEY=

# Validator's own bucket (samples, uploads)
HIPPIUS_VALIDATOR_ACCESS_KEY=
HIPPIUS_VALIDATOR_SECRET_KEY=

# Optional: for HuggingFace models
# HF_AUTH_TOKEN=

# =============================================================================
# OWNER
# =============================================================================

# Corpus bucket (source audio uploads)
HIPPIUS_OWNER_ACCESS_KEY=
HIPPIUS_OWNER_SECRET_KEY=

# Optional: override DB (defaults: localhost:5432, user vocence, db vocence)
# DB_CONNECTION_STRING=postgresql://user:pass@host:5432/vocence
