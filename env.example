# Vocence Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration (all chain operations use these)
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=102              # Subnet id: 102 (mainnet default). For testnet set NETWORK=test and NETUID=XXX.
# Optional aliases: CHAIN_NETWORK, SUBNET_ID (overridden by NETWORK, NETUID if set)

# Wallet Configuration
WALLET_NAME=default     # Name of your wallet
HOTKEY_NAME=default     # Name of your hotkey

# Chutes Integration (SN64)
CHUTES_API_KEY=         # API key for Chutes model hosting and inference

# Hippius S3 (SN75) - two roles:
#
# Owner (centralized service / source_audio_downloader): one set for corpus bucket
HIPPIUS_OWNER_ACCESS_KEY=    # Owner credentials (e.g. hip_...) for corpus bucket
HIPPIUS_OWNER_SECRET_KEY=    # Owner secret

# Validator: two sets — corpus (read owner's bucket) and validator's own (samples)
HIPPIUS_CORPUS_ACCESS_KEY=   # Owner-provided sub_key for corpus bucket (read-only)
HIPPIUS_CORPUS_SECRET_KEY=
HIPPIUS_VALIDATOR_ACCESS_KEY=   # Validator's own credentials (samples bucket)
HIPPIUS_VALIDATOR_SECRET_KEY=

# Validator name: used for the samples bucket (e.g. audio-samples-rt21, audio-samples-yuma). Set this in most cases.
VALIDATOR_NAME=rt21

# Bucket names (shared)
HIPPIUS_AUDIO_SOURCE_BUCKET=audio-corpus   # Corpus bucket (owner writes, validators read)
# Validator's samples bucket is audio-samples-{VALIDATOR_NAME} unless overridden:
# HIPPIUS_AUDIO_SAMPLES_BUCKET=audio-samples-rt21

# Serve process logs: daily .log files (UTC), one file per day. Default "logs". Set empty to disable.
# LOG_DIR=logs

# Validator: local copy of metadata.json (default: disabled). Set both to enable:
# VALIDATOR_SAVE_LOCAL_SAMPLES=false   # default; set true to save metadata locally
# VALIDATOR_LOCAL_SAMPLES_DIR=         # e.g. data/samples -> ./data/samples/{evaluation_id}/metadata.json (only used when SAVE is true)

# Validator: weight-setting runs every CYCLE_LENGTH blocks when block % CYCLE_LENGTH == CYCLE_OFFSET_BLOCKS (e.g. 165, 315, 465).
# CYCLE_LENGTH=150
# CYCLE_OFFSET_BLOCKS=15

# Validator: sample generation is block-based (every 150 blocks, staggered by validator ID). See VALIDATOR_ID.
# Validator ID 0–4: send tasks when block % 150 is 0, 30, 60, 90, 120 respectively (default ID 1 → offset 30).
# VALIDATOR_ID=1
# SAMPLE_SLOT_INTERVAL_BLOCKS=150

# Validator: max concurrent requests to miners' chutes per round. Default 20; lower if you hit rate limits.
# MAX_PARALLEL_MINERS=20

# Validator: max concurrent OpenAI evaluations (forced-choice) per round. Default 4; lower if you hit OpenAI rate limits.
# MAX_PARALLEL_EVALS=4

# Scoring: use only the most recent N evaluations (validator weight-setting + owner dashboard metrics). Default 50.
# MAX_EVALS_FOR_SCORING=50

# Miner eligibility: must have more than 35 evals in that window to compete for weights. Default 36.
# MIN_EVALS_TO_COMPETE=36

# Legacy (optional): HIPPIUS_ACCESS_KEY / HIPPIUS_SECRET_KEY used as fallback for owner or validator
HIPPIUS_KEY=            # Deprecated; use OWNER_* or VALIDATOR_* / CORPUS_*
HIPPIUS_IPFS_URL=http://localhost:5001  # IPFS node URL for Hippius

# --- Owner / Centralized API (vocence api / vocence owner serve) ---
# PostgreSQL (required for API: participants, evaluations, blocklist, metrics)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vocence
POSTGRES_PASSWORD=vocence
POSTGRES_DB=vocence
# Or set a single URL: DB_CONNECTION_STRING=postgresql://user:pass@host:5432/vocence

# API server binding
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
